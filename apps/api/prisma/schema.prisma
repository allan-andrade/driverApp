generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CANDIDATE
  INSTRUCTOR
  SCHOOL_MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InstructorType {
  AUTONOMO
  SCHOOL_LINKED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  APPROVED
  REJECTED
}

enum LinkStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum CnhCategory {
  A
  B
  AB
  C
  D
  E
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
}

enum LessonStatus {
  SCHEDULED
  CHECK_IN_PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LearningStage {
  BEGINNER
  INTERMEDIATE
  PRE_EXAM
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  PAID
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentMethod {
  PIX
  CARD
  CASH
  MANUAL
}

enum PayoutStatus {
  PENDING
  SCHEDULED
  PAID
  FAILED
  ON_HOLD
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
  CANCELLED
}

enum IncidentType {
  SAFETY
  HARASSMENT
  NO_SHOW
  FRAUD
  VEHICLE_ISSUE
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum EntityType {
  USER
  CANDIDATE_PROFILE
  INSTRUCTOR_PROFILE
  SCHOOL
  VEHICLE
  BOOKING
  LESSON
  PAYMENT
  PAYOUT
  DISPUTE
  INCIDENT_REPORT
  STATE_POLICY
  DOCUMENT_REQUIREMENT
  DOCUMENT_SUBMISSION
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  phone              String?
  passwordHash       String
  role               UserRole
  status             UserStatus          @default(ACTIVE)
  refreshTokenHash   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  candidateProfile   CandidateProfile?
  instructorProfile  InstructorProfile?
  schoolManager      School?
  auditLogs          AuditLog[]
  disputesOpened     Dispute[]            @relation("DisputeOpenedBy")
  incidentReports    IncidentReport[]     @relation("IncidentReportedBy")
  incidentReported   IncidentReport[]     @relation("IncidentReportedUser")
  documentSubmissions DocumentSubmission[] @relation("DocumentSubmissionUser")
  reviewedSubmissions DocumentSubmission[] @relation("DocumentSubmissionReviewer")

  @@index([role])
  @@index([status])
}

model CandidateProfile {
  id                        String         @id @default(cuid())
  userId                    String         @unique
  fullName                  String
  cpf                       String?        @unique
  birthDate                 DateTime?
  state                     String?
  city                      String?
  targetCategory            CnhCategory?
  learningStage             LearningStage?
  hasVehicle                Boolean        @default(false)
  preferredLanguage         String?
  preferredInstructorGender String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  user                      User           @relation(fields: [userId], references: [id])
  bookings                  Booking[]
  lessons                   Lesson[]
  reviews                   Review[]
  payments                  Payment[]

  @@index([state, city])
}

model InstructorProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique
  instructorType     InstructorType
  verificationStatus VerificationStatus  @default(PENDING)
  bio                String?
  yearsExperience    Int?
  serviceRadiusKm    Int?
  basePrice          Decimal?            @db.Decimal(10, 2)
  isActive           Boolean             @default(true)
  categories         CnhCategory[]       @default([])
  city               String?
  state              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id])
  schoolLinks        InstructorSchoolLink[]
  vehicles           Vehicle[]
  availabilitySlots  AvailabilitySlot[]
  packages           Package[]
  bookings           Booking[]
  lessons            Lesson[]
  reviews            Review[]
  payments           Payment[]
  payouts            Payout[]
  documentSubmissions DocumentSubmission[]

  @@index([verificationStatus, isActive])
  @@index([city, state])
}

model School {
  id                 String              @id @default(cuid())
  legalName          String
  tradeName          String
  cnpj               String              @unique
  verificationStatus VerificationStatus  @default(PENDING)
  address            String?
  city               String?
  state              String?
  managerUserId      String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  manager            User?               @relation(fields: [managerUserId], references: [id])
  instructorLinks    InstructorSchoolLink[]
  vehicles           Vehicle[]
  packages           Package[]
  bookings           Booking[]
  payments           Payment[]
  payouts            Payout[]
  documentSubmissions DocumentSubmission[]

  @@index([state, city])
}

model InstructorSchoolLink {
  id                  String      @id @default(cuid())
  instructorProfileId String
  schoolId            String
  status              LinkStatus  @default(PENDING)
  createdAt           DateTime    @default(now())
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
  school              School      @relation(fields: [schoolId], references: [id])

  @@unique([instructorProfileId, schoolId])
}

model Vehicle {
  id                 String              @id @default(cuid())
  instructorProfileId String?
  schoolId           String?
  plate              String              @unique
  brand              String
  model              String
  year               Int
  transmissionType   TransmissionType
  categorySupported  CnhCategory
  verificationStatus VerificationStatus  @default(PENDING)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  instructorProfile  InstructorProfile?  @relation(fields: [instructorProfileId], references: [id])
  school             School?             @relation(fields: [schoolId], references: [id])
  lessons            Lesson[]
}

model AvailabilitySlot {
  id                  String            @id @default(cuid())
  instructorProfileId String
  weekday             Int
  startTime           String
  endTime             String
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
}

model Package {
  id                   String            @id @default(cuid())
  instructorProfileId  String?
  schoolId             String?
  title                String
  lessonCount          Int
  durationMinutes      Int
  category             CnhCategory
  price                Decimal           @db.Decimal(10, 2)
  usesInstructorVehicle Boolean          @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  instructorProfile    InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school               School?           @relation(fields: [schoolId], references: [id])
  bookings             Booking[]
}

model Booking {
  id                  String            @id @default(cuid())
  candidateProfileId  String
  instructorProfileId String?
  schoolId            String?
  packageId           String?
  scheduledStart      DateTime
  scheduledEnd        DateTime
  priceTotal          Decimal           @db.Decimal(10, 2)
  platformFee         Decimal           @db.Decimal(10, 2)
  status              BookingStatus     @default(PENDING)
  paymentStatus       PaymentStatus     @default(PENDING)
  cancelReason        String?
  rescheduleReason    String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  candidateProfile    CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
  instructorProfile   InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school              School?           @relation(fields: [schoolId], references: [id])
  package             Package?          @relation(fields: [packageId], references: [id])
  lessons             Lesson[]
  reviews             Review[]
  payments            Payment[]
  disputes            Dispute[]
  incidentReports     IncidentReport[]
}

model Lesson {
  id                  String            @id @default(cuid())
  bookingId           String
  candidateProfileId  String
  instructorProfileId String
  vehicleId           String?
  pinCode             String
  pinVerified         Boolean           @default(false)
  startedAt           DateTime?
  finishedAt          DateTime?
  status              LessonStatus      @default(SCHEDULED)
  startLat            Float?
  startLng            Float?
  endLat              Float?
  endLng              Float?
  startAddress        String?
  endAddress          String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  booking             Booking           @relation(fields: [bookingId], references: [id])
  candidateProfile    CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
  vehicle             Vehicle?          @relation(fields: [vehicleId], references: [id])
  disputes            Dispute[]
  incidentReports     IncidentReport[]
}

model Review {
  id                  String            @id @default(cuid())
  bookingId           String
  candidateProfileId  String
  instructorProfileId String
  punctuality         Int
  didactics           Int
  professionalism     Int
  safety              Int
  examReadiness       Int
  comment             String?
  createdAt           DateTime          @default(now())
  booking             Booking           @relation(fields: [bookingId], references: [id])
  candidateProfile    CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
}

model StatePolicy {
  id          String   @id @default(cuid())
  stateCode   String
  isActive    Boolean  @default(true)
  rulesJson   Json
  examFlowJson Json
  docsJson    Json
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([stateCode])
  @@index([isActive])
}

model DocumentRequirement {
  id           String   @id @default(cuid())
  entityType   EntityType
  stateCode    String
  name         String
  required     Boolean  @default(true)
  metadataJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  EntityType
  entityId    String
  action      String
  metadataJson Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Payment {
  id                 String        @id @default(cuid())
  bookingId          String
  candidateProfileId String
  instructorProfileId String?
  schoolId           String?
  providerReference  String?
  status             PaymentStatus @default(PENDING)
  amount             Decimal       @db.Decimal(10, 2)
  platformFee        Decimal       @default(0) @db.Decimal(10, 2)
  currency           String        @default("BRL")
  method             PaymentMethod @default(MANUAL)
  capturedAt         DateTime?
  refundedAt         DateTime?
  provider           String?
  providerPaymentId  String?
  splitMetadataJson  Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  booking            Booking       @relation(fields: [bookingId], references: [id])
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id])
  instructorProfile  InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school             School?       @relation(fields: [schoolId], references: [id])
  payouts            Payout[]
  disputes           Dispute[]
}

model Payout {
  id                 String       @id @default(cuid())
  paymentId          String
  instructorProfileId String?
  schoolId           String?
  amountNet          Decimal      @db.Decimal(10, 2)
  status             PayoutStatus @default(PENDING)
  scheduledAt        DateTime?
  paidAt             DateTime?
  provider           String?
  providerReference  String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  payment            Payment      @relation(fields: [paymentId], references: [id])
  instructorProfile  InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school             School?      @relation(fields: [schoolId], references: [id])
}

model Dispute {
  id                 String       @id @default(cuid())
  bookingId          String?
  lessonId           String?
  paymentId          String?
  openedByUserId     String
  reason             String
  description        String?
  status             DisputeStatus @default(OPEN)
  resolution         String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  booking            Booking?     @relation(fields: [bookingId], references: [id])
  lesson             Lesson?      @relation(fields: [lessonId], references: [id])
  payment            Payment?     @relation(fields: [paymentId], references: [id])
  openedBy           User         @relation("DisputeOpenedBy", fields: [openedByUserId], references: [id])
}

model IncidentReport {
  id                 String         @id @default(cuid())
  lessonId           String?
  bookingId          String?
  reporterUserId     String
  reportedUserId     String?
  type               IncidentType
  severity           IncidentSeverity
  description        String
  evidenceUrl        String?
  status             IncidentStatus     @default(OPEN)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  lesson             Lesson?        @relation(fields: [lessonId], references: [id])
  booking            Booking?       @relation(fields: [bookingId], references: [id])
  reporterUser       User           @relation("IncidentReportedBy", fields: [reporterUserId], references: [id])
  reportedUser       User?          @relation("IncidentReportedUser", fields: [reportedUserId], references: [id])
}

model DocumentSubmission {
  id                  String             @id @default(cuid())
  userId              String?
  instructorProfileId String?
  schoolId            String?
  stateCode           String
  documentType        String
  verificationStatus  VerificationStatus @default(PENDING)
  fileUrl             String
  metadataJson        Json?
  reviewedByUserId    String?
  reviewedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User?              @relation("DocumentSubmissionUser", fields: [userId], references: [id])
  instructorProfile   InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school              School?            @relation(fields: [schoolId], references: [id])
  reviewedByUser      User?              @relation("DocumentSubmissionReviewer", fields: [reviewedByUserId], references: [id])
}
