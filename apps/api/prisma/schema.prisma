generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CANDIDATE
  INSTRUCTOR
  SCHOOL_MANAGER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InstructorType {
  AUTONOMO
  SCHOOL_LINKED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  APPROVED
  REJECTED
}

enum LinkStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
}

enum CnhCategory {
  A
  B
  AB
  C
  D
  E
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
}

enum LessonStatus {
  SCHEDULED
  CHECK_IN_PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LearningStage {
  BEGINNER
  INTERMEDIATE
  PRE_EXAM
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  PAID
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentMethod {
  PIX
  CARD
  CASH
  MANUAL
}

enum PayoutStatus {
  PENDING
  SCHEDULED
  PAID
  FAILED
  ON_HOLD
}

enum WalletOwnerType {
  USER
  INSTRUCTOR
  SCHOOL
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  HOLD
  RELEASE
  REFUND
  PAYOUT
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  LESSON_REMINDER
  LESSON_STARTED
  LESSON_COMPLETED
  PAYMENT_UPDATED
  PAYOUT_UPDATED
  DOCUMENT_REVIEWED
  INCIDENT_UPDATED
  DISPUTE_UPDATED
  SYSTEM
}

enum DocumentReviewDecision {
  APPROVED
  REJECTED
  REQUEST_CHANGES
}

enum PaymentAttemptStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum PaymentSplitStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  ON_HOLD
}

enum RecipientType {
  PLATFORM
  INSTRUCTOR
  SCHOOL
}

enum ChatMessageType {
  TEXT
  SYSTEM
  BOOKING_UPDATE
}

enum LessonLocationEventType {
  CHECK_IN
  START
  FINISH
  MANUAL_MARK
}

enum ReminderType {
  BOOKING_REMINDER
  LESSON_REMINDER
  PAYMENT_CONFIRMATION
  DOCUMENT_REMINDER
}

enum ReminderChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum FraudSignalType {
  MULTIPLE_CANCELS
  HIGH_RISK_PAYMENT
  DEVICE_MISMATCH
  GEO_MISMATCH
  DUPLICATE_ACCOUNT
  ABNORMAL_BOOKING_PATTERN
  OTHER
}

enum FraudSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WebhookProvider {
  STRIPE
  PAGARME
  ASAAS
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
  CANCELLED
}

enum IncidentType {
  SAFETY
  HARASSMENT
  NO_SHOW
  FRAUD
  VEHICLE_ISSUE
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum EntityType {
  USER
  CANDIDATE_PROFILE
  INSTRUCTOR_PROFILE
  SCHOOL
  VEHICLE
  BOOKING
  LESSON
  PAYMENT
  PAYOUT
  DISPUTE
  INCIDENT_REPORT
  STATE_POLICY
  DOCUMENT_REQUIREMENT
  DOCUMENT_SUBMISSION
  INSTRUCTOR_METRICS
  WALLET
  WALLET_TRANSACTION
  NOTIFICATION
  NOTIFICATION_PREFERENCE
  DOCUMENT_REVIEW
  MATCHING_SNAPSHOT
  PAYMENT_ATTEMPT
  PAYMENT_SPLIT
  CHAT_CONVERSATION
  CHAT_MESSAGE
  LESSON_LOCATION_EVENT
  REMINDER_JOB_LOG
  FRAUD_SIGNAL
  WEBHOOK_EVENT
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  phone              String?
  passwordHash       String
  role               UserRole
  status             UserStatus          @default(ACTIVE)
  refreshTokenHash   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  candidateProfile   CandidateProfile?
  instructorProfile  InstructorProfile?
  schoolManager      School?
  auditLogs          AuditLog[]
  disputesOpened     Dispute[]            @relation("DisputeOpenedBy")
  incidentReports    IncidentReport[]     @relation("IncidentReportedBy")
  incidentReported   IncidentReport[]     @relation("IncidentReportedUser")
  documentSubmissions DocumentSubmission[] @relation("DocumentSubmissionUser")
  reviewedSubmissions DocumentSubmission[] @relation("DocumentSubmissionReviewer")
  notifications      Notification[]
  notificationPreference NotificationPreference?
  documentReviews    DocumentReview[]     @relation("DocumentReviewReviewer")
  wallets            Wallet[]             @relation("WalletOwner")
  chatMessages       ChatMessage[]        @relation("ChatMessageSender")
  reminderLogs       ReminderJobLog[]
  fraudSignals       FraudSignal[]

  @@index([role])
  @@index([status])
}

model CandidateProfile {
  id                        String         @id @default(cuid())
  userId                    String         @unique
  fullName                  String
  cpf                       String?        @unique
  birthDate                 DateTime?
  state                     String?
  city                      String?
  targetCategory            CnhCategory?
  learningStage             LearningStage?
  hasVehicle                Boolean        @default(false)
  preferredLanguage         String?
  preferredInstructorGender String?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  user                      User           @relation(fields: [userId], references: [id])
  bookings                  Booking[]
  lessons                   Lesson[]
  reviews                   Review[]
  payments                  Payment[]
  matchingSnapshots         MatchingSnapshot[]
  chatConversations         ChatConversation[]

  @@index([state, city])
}

model InstructorProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique
  instructorType     InstructorType
  verificationStatus VerificationStatus  @default(PENDING)
  bio                String?
  yearsExperience    Int?
  serviceRadiusKm    Int?
  basePrice          Decimal?            @db.Decimal(10, 2)
  isActive           Boolean             @default(true)
  categories         CnhCategory[]       @default([])
  city               String?
  state              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id])
  schoolLinks        InstructorSchoolLink[]
  vehicles           Vehicle[]
  availabilitySlots  AvailabilitySlot[]
  packages           Package[]
  bookings           Booking[]
  lessons            Lesson[]
  reviews            Review[]
  payments           Payment[]
  payouts            Payout[]
  documentSubmissions DocumentSubmission[]
  metrics            InstructorMetrics?
  wallet             Wallet?
  matchingSnapshots  MatchingSnapshot[]
  chatConversations  ChatConversation[]

  @@index([verificationStatus, isActive])
  @@index([city, state])
}

model School {
  id                 String              @id @default(cuid())
  legalName          String
  tradeName          String
  cnpj               String              @unique
  verificationStatus VerificationStatus  @default(PENDING)
  address            String?
  city               String?
  state              String?
  managerUserId      String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  manager            User?               @relation(fields: [managerUserId], references: [id])
  instructorLinks    InstructorSchoolLink[]
  vehicles           Vehicle[]
  packages           Package[]
  bookings           Booking[]
  payments           Payment[]
  payouts            Payout[]
  documentSubmissions DocumentSubmission[]
  wallet             Wallet?
  chatConversations  ChatConversation[]

  @@index([state, city])
}

model InstructorSchoolLink {
  id                  String      @id @default(cuid())
  instructorProfileId String
  schoolId            String
  status              LinkStatus  @default(PENDING)
  createdAt           DateTime    @default(now())
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
  school              School      @relation(fields: [schoolId], references: [id])

  @@unique([instructorProfileId, schoolId])
}

model Vehicle {
  id                 String              @id @default(cuid())
  instructorProfileId String?
  schoolId           String?
  plate              String              @unique
  brand              String
  model              String
  year               Int
  transmissionType   TransmissionType
  categorySupported  CnhCategory
  verificationStatus VerificationStatus  @default(PENDING)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  instructorProfile  InstructorProfile?  @relation(fields: [instructorProfileId], references: [id])
  school             School?             @relation(fields: [schoolId], references: [id])
  lessons            Lesson[]
}

model AvailabilitySlot {
  id                  String            @id @default(cuid())
  instructorProfileId String
  weekday             Int
  startTime           String
  endTime             String
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
}

model Package {
  id                   String            @id @default(cuid())
  instructorProfileId  String?
  schoolId             String?
  title                String
  lessonCount          Int
  durationMinutes      Int
  category             CnhCategory
  price                Decimal           @db.Decimal(10, 2)
  usesInstructorVehicle Boolean          @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  instructorProfile    InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school               School?           @relation(fields: [schoolId], references: [id])
  bookings             Booking[]
}

model Booking {
  id                  String            @id @default(cuid())
  candidateProfileId  String
  instructorProfileId String?
  schoolId            String?
  packageId           String?
  scheduledStart      DateTime
  scheduledEnd        DateTime
  priceTotal          Decimal           @db.Decimal(10, 2)
  platformFee         Decimal           @db.Decimal(10, 2)
  status              BookingStatus     @default(PENDING)
  paymentStatus       PaymentStatus     @default(PENDING)
  cancelReason        String?
  rescheduleReason    String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  candidateProfile    CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
  instructorProfile   InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school              School?           @relation(fields: [schoolId], references: [id])
  package             Package?          @relation(fields: [packageId], references: [id])
  lessons             Lesson[]
  reviews             Review[]
  payments            Payment[]
  disputes            Dispute[]
  incidentReports     IncidentReport[]
  chatConversations   ChatConversation[]
  reminderLogs        ReminderJobLog[]
  fraudSignals        FraudSignal[]
}

model Lesson {
  id                  String            @id @default(cuid())
  bookingId           String
  candidateProfileId  String
  instructorProfileId String
  vehicleId           String?
  pinCode             String
  pinVerified         Boolean           @default(false)
  startedAt           DateTime?
  finishedAt          DateTime?
  status              LessonStatus      @default(SCHEDULED)
  startLat            Float?
  startLng            Float?
  endLat              Float?
  endLng              Float?
  startAddress        String?
  endAddress          String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  booking             Booking           @relation(fields: [bookingId], references: [id])
  candidateProfile    CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
  vehicle             Vehicle?          @relation(fields: [vehicleId], references: [id])
  disputes            Dispute[]
  incidentReports     IncidentReport[]
  locationEvents      LessonLocationEvent[]
  reminderLogs        ReminderJobLog[]
  fraudSignals        FraudSignal[]
}

model Review {
  id                  String            @id @default(cuid())
  bookingId           String
  candidateProfileId  String
  instructorProfileId String
  punctuality         Int
  didactics           Int
  professionalism     Int
  safety              Int
  examReadiness       Int
  comment             String?
  createdAt           DateTime          @default(now())
  booking             Booking           @relation(fields: [bookingId], references: [id])
  candidateProfile    CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
}

model StatePolicy {
  id          String   @id @default(cuid())
  stateCode   String
  isActive    Boolean  @default(true)
  rulesJson   Json
  examFlowJson Json
  docsJson    Json
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([stateCode])
  @@index([isActive])
}

model DocumentRequirement {
  id           String   @id @default(cuid())
  entityType   EntityType
  stateCode    String
  name         String
  required     Boolean  @default(true)
  metadataJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  EntityType
  entityId    String
  action      String
  metadataJson Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Payment {
  id                 String        @id @default(cuid())
  bookingId          String
  candidateProfileId String
  instructorProfileId String?
  schoolId           String?
  providerReference  String?
  status             PaymentStatus @default(PENDING)
  amount             Decimal       @db.Decimal(10, 2)
  platformFee        Decimal       @default(0) @db.Decimal(10, 2)
  currency           String        @default("BRL")
  method             PaymentMethod @default(MANUAL)
  capturedAt         DateTime?
  refundedAt         DateTime?
  provider           String?
  providerPaymentId  String?
  splitMetadataJson  Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  booking            Booking       @relation(fields: [bookingId], references: [id])
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id])
  instructorProfile  InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school             School?       @relation(fields: [schoolId], references: [id])
  payouts            Payout[]
  disputes           Dispute[]
  attempts           PaymentAttempt[]
  splits             PaymentSplit[]
  fraudSignals       FraudSignal[]
}

model Payout {
  id                 String       @id @default(cuid())
  paymentId          String
  instructorProfileId String?
  schoolId           String?
  amountNet          Decimal      @db.Decimal(10, 2)
  status             PayoutStatus @default(PENDING)
  scheduledAt        DateTime?
  paidAt             DateTime?
  provider           String?
  providerReference  String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  payment            Payment      @relation(fields: [paymentId], references: [id])
  instructorProfile  InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school             School?      @relation(fields: [schoolId], references: [id])
}

model Dispute {
  id                 String       @id @default(cuid())
  bookingId          String?
  lessonId           String?
  paymentId          String?
  openedByUserId     String
  reason             String
  description        String?
  status             DisputeStatus @default(OPEN)
  resolution         String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  booking            Booking?     @relation(fields: [bookingId], references: [id])
  lesson             Lesson?      @relation(fields: [lessonId], references: [id])
  payment            Payment?     @relation(fields: [paymentId], references: [id])
  openedBy           User         @relation("DisputeOpenedBy", fields: [openedByUserId], references: [id])
}

model IncidentReport {
  id                 String         @id @default(cuid())
  lessonId           String?
  bookingId          String?
  reporterUserId     String
  reportedUserId     String?
  type               IncidentType
  severity           IncidentSeverity
  description        String
  evidenceUrl        String?
  status             IncidentStatus     @default(OPEN)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  lesson             Lesson?        @relation(fields: [lessonId], references: [id])
  booking            Booking?       @relation(fields: [bookingId], references: [id])
  reporterUser       User           @relation("IncidentReportedBy", fields: [reporterUserId], references: [id])
  reportedUser       User?          @relation("IncidentReportedUser", fields: [reportedUserId], references: [id])
}

model DocumentSubmission {
  id                  String             @id @default(cuid())
  userId              String?
  instructorProfileId String?
  schoolId            String?
  stateCode           String
  documentType        String
  verificationStatus  VerificationStatus @default(PENDING)
  fileUrl             String
  metadataJson        Json?
  reviewedByUserId    String?
  reviewedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User?              @relation("DocumentSubmissionUser", fields: [userId], references: [id])
  instructorProfile   InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school              School?            @relation(fields: [schoolId], references: [id])
  reviewedByUser      User?              @relation("DocumentSubmissionReviewer", fields: [reviewedByUserId], references: [id])
  reviews             DocumentReview[]
}

model InstructorMetrics {
  id                  String            @id @default(cuid())
  instructorProfileId String            @unique
  averageRating       Decimal           @default(0) @db.Decimal(5, 2)
  punctualityAvg      Decimal           @default(0) @db.Decimal(5, 2)
  didacticsAvg        Decimal           @default(0) @db.Decimal(5, 2)
  professionalismAvg  Decimal           @default(0) @db.Decimal(5, 2)
  safetyAvg           Decimal           @default(0) @db.Decimal(5, 2)
  examReadinessAvg    Decimal           @default(0) @db.Decimal(5, 2)
  totalReviews        Int               @default(0)
  completedLessons    Int               @default(0)
  cancelledBookings   Int               @default(0)
  noShowCount         Int               @default(0)
  attendanceRate      Decimal           @default(0) @db.Decimal(5, 2)
  completionRate      Decimal           @default(0) @db.Decimal(5, 2)
  trustScore          Decimal           @default(0) @db.Decimal(5, 2)
  teachingScore       Decimal           @default(0) @db.Decimal(5, 2)
  marketplaceScore    Decimal           @default(0) @db.Decimal(5, 2)
  updatedAt           DateTime          @updatedAt
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])
}

model Wallet {
  id                  String              @id @default(cuid())
  ownerType           WalletOwnerType
  ownerUserId         String?
  instructorProfileId String?             @unique
  schoolId            String?             @unique
  currency            String              @default("BRL")
  balanceAvailable    Decimal             @default(0) @db.Decimal(12, 2)
  balancePending      Decimal             @default(0) @db.Decimal(12, 2)
  balanceOnHold       Decimal             @default(0) @db.Decimal(12, 2)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  transactions        WalletTransaction[]
  instructorProfile   InstructorProfile?  @relation(fields: [instructorProfileId], references: [id])
  school              School?             @relation(fields: [schoolId], references: [id])
  ownerUser           User?               @relation("WalletOwner", fields: [ownerUserId], references: [id])

  @@unique([ownerType, ownerUserId])
}

model WalletTransaction {
  id            String                @id @default(cuid())
  walletId      String
  type          WalletTransactionType
  amount        Decimal               @db.Decimal(12, 2)
  currency      String                @default("BRL")
  referenceType EntityType
  referenceId   String
  description   String?
  createdAt     DateTime              @default(now())
  wallet        Wallet                @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@index([referenceType, referenceId])
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  payloadJson Json?
  readAt      DateTime?
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  emailEnabled    Boolean  @default(false)
  pushEnabled     Boolean  @default(false)
  inAppEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(false)
  bookingUpdates  Boolean  @default(true)
  lessonUpdates   Boolean  @default(true)
  paymentUpdates  Boolean  @default(true)
  safetyAlerts    Boolean  @default(true)
  marketingEnabled Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model DocumentReview {
  id                   String                 @id @default(cuid())
  documentSubmissionId String
  reviewedByUserId     String
  decision             DocumentReviewDecision
  reason               String?
  metadataJson         Json?
  createdAt            DateTime               @default(now())
  documentSubmission   DocumentSubmission     @relation(fields: [documentSubmissionId], references: [id])
  reviewedByUser       User                   @relation("DocumentReviewReviewer", fields: [reviewedByUserId], references: [id])

  @@index([documentSubmissionId, createdAt])
}

model MatchingSnapshot {
  id                  String            @id @default(cuid())
  candidateProfileId  String?
  instructorProfileId String
  score               Decimal           @db.Decimal(5, 2)
  factorsJson         Json
  createdAt           DateTime          @default(now())
  candidateProfile    CandidateProfile? @relation(fields: [candidateProfileId], references: [id])
  instructorProfile   InstructorProfile @relation(fields: [instructorProfileId], references: [id])

  @@index([candidateProfileId, createdAt])
  @@index([instructorProfileId, createdAt])
}

model PaymentAttempt {
  id                String               @id @default(cuid())
  paymentId         String
  provider          WebhookProvider
  providerReference String?
  status            PaymentAttemptStatus @default(PENDING)
  requestJson       Json?
  responseJson      Json?
  errorMessage      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  payment           Payment              @relation(fields: [paymentId], references: [id])

  @@index([paymentId, createdAt])
  @@index([provider, providerReference])
}

model PaymentSplit {
  id                String            @id @default(cuid())
  paymentId         String
  recipientType     RecipientType
  recipientId       String
  amount            Decimal           @db.Decimal(12, 2)
  feeAmount         Decimal           @default(0) @db.Decimal(12, 2)
  status            PaymentSplitStatus @default(PENDING)
  providerReference String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  payment           Payment           @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([recipientType, recipientId])
  @@index([status, createdAt])
}

model ChatConversation {
  id                  String             @id @default(cuid())
  bookingId           String?
  candidateProfileId  String?
  instructorProfileId String?
  schoolId            String?
  lastMessageAt       DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  booking             Booking?           @relation(fields: [bookingId], references: [id])
  candidateProfile    CandidateProfile?  @relation(fields: [candidateProfileId], references: [id])
  instructorProfile   InstructorProfile? @relation(fields: [instructorProfileId], references: [id])
  school              School?            @relation(fields: [schoolId], references: [id])
  messages            ChatMessage[]

  @@index([bookingId])
  @@index([candidateProfileId, instructorProfileId])
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  senderUserId   String
  type           ChatMessageType @default(TEXT)
  content        String
  metadataJson   Json?
  readAt         DateTime?
  createdAt      DateTime        @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])
  senderUser     User             @relation("ChatMessageSender", fields: [senderUserId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
}

model LessonLocationEvent {
  id         String                @id @default(cuid())
  lessonId   String
  eventType  LessonLocationEventType
  lat        Float
  lng        Float
  accuracy   Float?
  address    String?
  recordedAt DateTime              @default(now())
  createdAt  DateTime              @default(now())
  lesson     Lesson                @relation(fields: [lessonId], references: [id])

  @@index([lessonId, recordedAt])
}

model ReminderJobLog {
  id          String          @id @default(cuid())
  userId      String?
  bookingId   String?
  lessonId    String?
  type        ReminderType
  channel     ReminderChannel
  status      String
  payloadJson Json?
  processedAt DateTime?
  createdAt   DateTime        @default(now())
  user        User?           @relation(fields: [userId], references: [id])
  booking     Booking?        @relation(fields: [bookingId], references: [id])
  lesson      Lesson?         @relation(fields: [lessonId], references: [id])

  @@index([type, channel, createdAt])
  @@index([bookingId, lessonId])
}

model FraudSignal {
  id          String          @id @default(cuid())
  userId      String?
  paymentId   String?
  bookingId   String?
  lessonId    String?
  signalType  FraudSignalType
  severity    FraudSeverity
  score       Int
  description String?
  metadataJson Json?
  createdAt   DateTime        @default(now())
  user        User?           @relation(fields: [userId], references: [id])
  payment     Payment?        @relation(fields: [paymentId], references: [id])
  booking     Booking?        @relation(fields: [bookingId], references: [id])
  lesson      Lesson?         @relation(fields: [lessonId], references: [id])

  @@index([signalType, severity, createdAt])
  @@index([paymentId, bookingId, lessonId])
}

model WebhookEvent {
  id                String          @id @default(cuid())
  provider          WebhookProvider
  eventType         String
  providerReference String?
  payloadJson       Json
  processed         Boolean         @default(false)
  processedAt       DateTime?
  errorMessage      String?
  createdAt         DateTime        @default(now())

  @@index([provider, createdAt])
  @@index([provider, providerReference])
  @@index([processed, createdAt])
}
